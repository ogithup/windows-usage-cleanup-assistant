<Application x:Class="WindowsUsageCleanupAssistant.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:WindowsUsageCleanupAssistant.ViewModels"
             xmlns:views="clr-namespace:WindowsUsageCleanupAssistant.Views">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Light"
                                             PrimaryColor="Teal"
                                             SecondaryColor="Amber" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Color x:Key="ShellBackgroundColor">#F4F1EA</Color>
            <SolidColorBrush x:Key="ShellBackgroundBrush" Color="{StaticResource ShellBackgroundColor}" />
            <SolidColorBrush x:Key="NavigationBrush" Color="#12363A" />
            <SolidColorBrush x:Key="CardBrush" Color="#FFFDF8" />

            <Style x:Key="PageCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource CardBrush}" />
                <Setter Property="CornerRadius" Value="22" />
                <Setter Property="Padding" Value="20" />
                <Setter Property="BorderBrush" Value="#E3DDD2" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>

            <Style x:Key="SummaryCardStyle" TargetType="Border" BasedOn="{StaticResource PageCardStyle}">
                <Setter Property="Margin" Value="0,0,16,0" />
            </Style>

            <Style x:Key="SummaryLabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#6B7B84" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="SummaryValueStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="28" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="#17494D" />
                <Setter Property="Margin" Value="0,10,0,0" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="#1F2A30" />
            </Style>

            <Style x:Key="RecommendationBadgeBorderStyle" TargetType="Border">
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="10,5" />
                <Setter Property="Background" Value="#E6ECEF" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Recommendation}" Value="CleanupCandidate">
                        <Setter Property="Background" Value="#FFE2C8" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Recommendation}" Value="DoNotRemove">
                        <Setter Property="Background" Value="#F7D7D7" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Recommendation}" Value="Keep">
                        <Setter Property="Background" Value="#D7EFDF" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Recommendation}" Value="Review">
                        <Setter Property="Background" Value="#E8E0CF" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="RecommendationBadgeTextStyle" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="#3C4C55" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Recommendation}" Value="CleanupCandidate">
                        <Setter Property="Foreground" Value="#A85B20" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Recommendation}" Value="DoNotRemove">
                        <Setter Property="Foreground" Value="#8B3232" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Recommendation}" Value="Keep">
                        <Setter Property="Foreground" Value="#2E6A4F" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="RiskBadgeBorderStyle" TargetType="Border">
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="10,5" />
                <Setter Property="Background" Value="#E6ECEF" />
            </Style>

            <Style x:Key="RiskBadgeTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#4E636D" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="FilterChipToggleStyle" TargetType="ToggleButton" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                <Setter Property="Margin" Value="0,0,12,8" />
                <Setter Property="Padding" Value="14,7" />
                <Style.Triggers>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter Property="Background" Value="#17494D" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="BorderBrush" Value="#17494D" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <DataTemplate DataType="{x:Type viewmodels:DashboardViewModel}">
                <views:DashboardView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodels:InstalledAppsViewModel}">
                <views:InstalledAppsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodels:UsageViewModel}">
                <views:UsageView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodels:CleanupViewModel}">
                <views:CleanupView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodels:ReportsViewModel}">
                <views:ReportsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodels:SettingsViewModel}">
                <views:SettingsView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>

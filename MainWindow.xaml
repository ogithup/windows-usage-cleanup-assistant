<Window x:Class="WindowsUsageCleanupAssistant.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Windows Usage Cleanup Assistant"
        Height="860"
        Width="1480"
        MinHeight="720"
        MinWidth="1180"
        Background="{StaticResource ShellBackgroundBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="{StaticResource NavigationBrush}"
                Padding="18">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,18">
                    <TextBlock FontSize="26"
                               FontWeight="Bold"
                               Foreground="White"
                               Text="Cleanup Assistant" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#C8D7D9"
                               Text="Windows usage, risk, and reclaim insights" 
                               TextWrapping="Wrap" />
                </StackPanel>

                <ListBox ItemsSource="{Binding NavigationItems}"
                         SelectedItem="{Binding SelectedNavigationItem}"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="White"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="0,0,0,10" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="ItemBorder"
                                                Background="Transparent"
                                                CornerRadius="18"
                                                Padding="14,12">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#245C60" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#1C4C50" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           Text="{Binding Title}" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="#C8D7D9"
                                           Text="{Binding Subtitle}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource PageCardStyle}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock FontSize="32"
                               FontWeight="Bold"
                               Foreground="#193237"
                               Text="{Binding CurrentSectionTitle}" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#6B7B84"
                               Text="{Binding CurrentSectionSubtitle}" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Style="{StaticResource PageCardStyle}">
                <ContentControl Content="{Binding CurrentPage}" />
            </Border>
        </Grid>
    </Grid>
</Window>

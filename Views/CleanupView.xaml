<UserControl x:Class="WindowsUsageCleanupAssistant.Views.CleanupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <WrapPanel Margin="0,0,0,16">
            <Button Style="{StaticResource MaterialDesignRaisedButton}"
                    Margin="0,0,12,0"
                    Command="{Binding DataContext.ScanCleanupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Content="Scan" />
            <Button Margin="0,0,12,0"
                    Command="{Binding DataContext.PreviewCleanupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Content="Preview" />
            <Button Margin="0,0,12,0"
                    Command="{Binding DataContext.CleanSelectedCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Content="Clean Selected" />
            <Button Margin="0,0,12,0"
                    Command="{Binding DataContext.GenerateCleanupReportCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Content="Generate Report" />
            <Button Command="{Binding DataContext.OpenCleanupLogCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Content="Show Skipped Items in Log" />
        </WrapPanel>

        <CheckBox Grid.Row="1"
                  Margin="0,0,0,16"
                  Content="Skip in-use files automatically (avoid one-by-one popups)"
                  IsChecked="{Binding SkipLockedFilesAutomatically}" />

        <Border Grid.Row="2" Style="{StaticResource PageCardStyle}" Margin="0,0,0,16">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Disk Cleanup Progress" />
                    <TextBlock Margin="20,3,0,0"
                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                               Text="{Binding SelectedSpaceMB, StringFormat=Selected: {0:N1} MB}" />
                </StackPanel>
                <TextBlock Margin="0,10,0,0"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                           Text="{Binding SkippedSummaryText}" />
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="3"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  ItemsSource="{Binding Categories}"
                  RowHeaderWidth="0">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Width="0.7*" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Header="Select" />
                <DataGridTextColumn Width="1.2*" Binding="{Binding CategoryName}" Header="Category" />
                <DataGridTextColumn Width="0.8*" Binding="{Binding FileCount}" Header="Files" />
                <DataGridTextColumn Width="0.9*" Binding="{Binding TotalSizeMB, StringFormat={}{0:N1}}" Header="Size (MB)" />
                <DataGridTemplateColumn Width="0.8*" Header="Risk">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource RiskBadgeBorderStyle}">
                                <TextBlock Style="{StaticResource RiskBadgeTextStyle}" Text="{Binding RiskLevel}" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Width="2.4*" Binding="{Binding Description}" Header="Description" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="4"
                   Margin="0,12,0,0"
                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                   Text="{Binding StatusText}" />
    </Grid>
</UserControl>

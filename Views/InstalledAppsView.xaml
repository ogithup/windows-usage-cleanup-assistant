<UserControl x:Class="WindowsUsageCleanupAssistant.Views.InstalledAppsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,16">
            <Button DockPanel.Dock="Right"
                    Width="130"
                    Margin="12,0,0,0"
                    Command="{Binding DataContext.UninstallSelectedCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Content="Safe Uninstall" />
            <Button DockPanel.Dock="Right"
                    Width="110"
                    Command="{Binding DataContext.RefreshCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Content="Refresh" />
            <TextBox Margin="0,0,12,0"
                     materialDesign:HintAssist.Hint="Search apps, publishers, process names, explanations"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
        </DockPanel>

        <WrapPanel Grid.Row="1" Margin="0,0,0,16">
            <ToggleButton Style="{StaticResource FilterChipToggleStyle}" IsChecked="{Binding ShowLargePrograms}" Content="Large Programs" />
            <ToggleButton Style="{StaticResource FilterChipToggleStyle}" IsChecked="{Binding ShowUnusedPrograms}" Content="Unused 6+ Months" />
            <ToggleButton Style="{StaticResource FilterChipToggleStyle}" IsChecked="{Binding ShowSdkRuntime}" Content="SDK / Runtime" />
            <ToggleButton Style="{StaticResource FilterChipToggleStyle}" IsChecked="{Binding ShowGames}" Content="Games" />
            <ToggleButton Style="{StaticResource FilterChipToggleStyle}" IsChecked="{Binding ShowDevelopmentTools}" Content="Development Tools" />
            <ToggleButton Style="{StaticResource FilterChipToggleStyle}" IsChecked="{Binding ShowSystemComponents}" Content="System Components" />
        </WrapPanel>

        <DataGrid Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  ItemsSource="{Binding ProgramsView}"
                  SelectedItem="{Binding SelectedProgram, Mode=TwoWay}"
                  RowHeaderWidth="0"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Width="1.4*" Binding="{Binding DisplayName}" Header="App" />
                <DataGridTextColumn Width="0.9*" Binding="{Binding CategoryLabel}" Header="Category" />
                <DataGridTemplateColumn Width="0.9*" Header="Recommendation">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource RecommendationBadgeBorderStyle}">
                                <TextBlock Style="{StaticResource RecommendationBadgeTextStyle}" Text="{Binding Recommendation}" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="0.9*" Header="Risk">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource RiskBadgeBorderStyle}">
                                <TextBlock Style="{StaticResource RiskBadgeTextStyle}" Text="{Binding SystemRiskScore}" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Width="0.8*" Binding="{Binding EstimatedSizeMB}" Header="MB" />
                <DataGridTextColumn Width="1*" Binding="{Binding LastUsedUtc, StringFormat={}{0:yyyy-MM-dd}}" Header="Last Used" />
                <DataGridTextColumn Width="1.1*" Binding="{Binding MatchedProcessName}" Header="Process" />
                <DataGridTextColumn Width="2.6*" Binding="{Binding LlmExplanation}" Header="Turkish Explanation" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="3"
                   Margin="0,12,0,0"
                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                   Text="{Binding StatusText}" />
    </Grid>
</UserControl>

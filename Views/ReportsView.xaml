<UserControl x:Class="WindowsUsageCleanupAssistant.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <UniformGrid Columns="2" Margin="0,0,0,20">
            <Border Style="{StaticResource SummaryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SummaryLabelStyle}" Text="Exportable Programs" />
                    <TextBlock Style="{StaticResource SummaryValueStyle}" Text="{Binding ExportableProgramCount}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SummaryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SummaryLabelStyle}" Text="Estimated Reclaimable" />
                    <TextBlock Style="{StaticResource SummaryValueStyle}" Text="{Binding ReclaimableSpaceMB, StringFormat={}{0:N1} MB}" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <WrapPanel Grid.Row="1" Margin="0,0,0,16">
            <Button Style="{StaticResource MaterialDesignRaisedButton}"
                    Margin="0,0,12,0"
                    Command="{Binding DataContext.ExportHtmlReportCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Content="Export HTML" />
            <Button Margin="0,0,12,0"
                    Command="{Binding DataContext.ExportCsvReportCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Content="Export CSV" />
            <Button Command="{Binding DataContext.ExportJsonReportCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Content="Export JSON" />
        </WrapPanel>

        <Border Grid.Row="2" Style="{StaticResource PageCardStyle}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Included Sections" />
                <TextBlock Margin="0,12,0,0" Text="- Summary cards" />
                <TextBlock Margin="0,6,0,0" Text="- Installed program table with explanations" />
                <TextBlock Margin="0,6,0,0" Text="- Unused programs table" />
                <TextBlock Margin="0,6,0,0" Text="- Cleanup candidates and dependency-sensitive tables" />
                <TextBlock Margin="0,6,0,0" Text="- Disk cleanup preview and recommendation reasons" />
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="3"
                   Margin="0,12,0,0"
                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                   Text="{Binding StatusText}" />
    </Grid>
</UserControl>
